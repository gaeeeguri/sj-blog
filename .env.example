# Shared secret checked against the `Authorization: Bearer <secret>` header on
# incoming POSTs to /api/health-webhook. Configure the same value as a custom
# header in health-connect-webhook's per-webhook "manage headers" UI.
HEALTH_WEBHOOK_SECRET=

# Fine-grained GitHub PAT scoped to this repo only, with "Contents: Read and write" permission.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
