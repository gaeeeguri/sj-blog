---
import type { FitnessStats } from '@/lib/fitness-stats';

interface Props {
  stats: FitnessStats;
}

const { stats } = Astro.props;

const numbers = [
  { label: 'this week', text: `${stats.thisWeekDistanceKm.toFixed(1)} km`, target: stats.thisWeekDistanceKm, decimals: 1, suffix: ' km' },
  { label: 'workouts', text: `${stats.totalWorkouts}`, target: stats.totalWorkouts, decimals: 0, suffix: '' },
  { label: 'streak', text: `${stats.currentStreakDays} d`, target: stats.currentStreakDays, decimals: 0, suffix: ' d' },
];
---

<div class="not-prose rounded-lg border border-border bg-card px-4 py-4" data-fitness-teaser>
  <div class="flex items-center justify-between">
    <span class="text-[11px] tracking-wide text-muted-foreground uppercase">Training log</span>
    <a href="/fitness" class="text-xs text-muted-foreground transition-colors hover:text-foreground">View fitness stats →</a>
  </div>
  <div class="mt-3 flex gap-6">
    {numbers.map((n) => (
      <div>
        <p
          class="font-mono text-lg font-semibold tabular-nums text-foreground"
          data-countup-target={n.target}
          data-countup-decimals={n.decimals}
          data-countup-suffix={n.suffix}
        >
          {n.text}
        </p>
        <p class="mt-0.5 text-[11px] tracking-wide text-muted-foreground uppercase">{n.label}</p>
      </div>
    ))}
  </div>
</div>

<script>
  function animateCountups(root: ParentNode) {
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const nodes = root.querySelectorAll<HTMLElement>('[data-fitness-teaser] [data-countup-target]');
    if (nodes.length === 0) return;

    if (reduceMotion) return;

    const DURATION = 700;
    const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);

    const run = (el: HTMLElement) => {
      const target = Number(el.dataset.countupTarget);
      const decimals = Number(el.dataset.countupDecimals ?? '0');
      const suffix = el.dataset.countupSuffix ?? '';
      if (Number.isNaN(target)) return;

      const start = performance.now();
      const step = (now: number) => {
        const progress = Math.min(1, (now - start) / DURATION);
        const value = target * easeOut(progress);
        el.textContent = `${value.toFixed(decimals)}${suffix}`;
        if (progress < 1) requestAnimationFrame(step);
        else el.textContent = `${target.toFixed(decimals)}${suffix}`;
      };
      requestAnimationFrame(step);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            run(entry.target as HTMLElement);
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.4 },
    );

    nodes.forEach((node) => observer.observe(node));
  }

  animateCountups(document);
  document.addEventListener('astro:page-load', () => animateCountups(document));
</script>
