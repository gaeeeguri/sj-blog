---
import { getCollection, render } from 'astro:content';
import EntryLayout from '@/layouts/EntryLayout.astro';
import { excludeWalking } from '@/lib/fitness-stats';

export async function getStaticPaths() {
  const entries = excludeWalking(
    await getCollection('fitness', ({ data }) => import.meta.env.DEV || !data.draft)
  );
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<EntryLayout
  title={entry.data.title}
  description={entry.data.description}
  pubDate={entry.data.pubDate}
  updatedDate={entry.data.updatedDate}
  tags={entry.data.tags}
  durationMinutes={entry.data.durationMinutes}
  distanceKm={entry.data.distanceKm}
  paceMinPerKm={entry.data.paceMinPerKm}
  avgHeartRate={entry.data.avgHeartRate}
  elevationM={entry.data.elevationM}
>
  <Content />
</EntryLayout>
