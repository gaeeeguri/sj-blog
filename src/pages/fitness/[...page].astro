---
import type { GetStaticPathsOptions } from 'astro';
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import FitnessCard from '@/components/fitness/FitnessCard.astro';
import StatsOverview from '@/components/fitness/StatsOverview.astro';
import TrendBarChart from '@/components/fitness/TrendBarChart.astro';
import CategoryDonut from '@/components/fitness/CategoryDonut.astro';
import TrainingHeatmap from '@/components/fitness/TrainingHeatmap.astro';
import { computeFitnessStats, excludeWalking } from '@/lib/fitness-stats';
import { buttonVariants } from '@/components/ui/button';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const entries = excludeWalking(
    await getCollection('fitness', ({ data }) => import.meta.env.DEV || !data.draft)
  ).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return paginate(entries, { pageSize: 24 });
}

const { page } = Astro.props;

const allEntries = excludeWalking(
  await getCollection('fitness', ({ data }) => import.meta.env.DEV || !data.draft)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const stats = computeFitnessStats(allEntries);

const filters = [
  { key: 'all', label: 'All' },
  { key: 'running', label: 'Running' },
  { key: 'workout', label: 'Workout' },
];
---

<Layout title="Fitness — sj-blog" description="Training log and workout statistics.">
  <h1 class="text-2xl font-bold tracking-tight">Fitness</h1>
  <p class="mt-2 text-muted-foreground">Auto-synced training log with running and workout stats.</p>

  <div class="mt-6">
    <StatsOverview stats={stats} />
  </div>

  <section class="mt-8">
    <h2 class="text-sm font-semibold text-muted-foreground">Activity</h2>
    <div class="mt-3">
      <TrainingHeatmap entries={allEntries} />
    </div>
  </section>

  <div class="mt-8 grid gap-4 sm:grid-cols-2">
    <CategoryDonut categoryBreakdown={stats.categoryBreakdown} />
    <TrendBarChart weeklyTrend={stats.weeklyTrend} metric="distanceKm" />
  </div>

  <section class="mt-10" data-fitness-list>
    <div class="flex items-center justify-between">
      <h2 class="text-sm font-semibold text-muted-foreground">Log</h2>
      <div class="flex gap-1.5" role="group" aria-label="Filter activities">
        {filters.map((f, i) => (
          <button
            type="button"
            data-filter={f.key}
            aria-pressed={i === 0 ? 'true' : 'false'}
            class={buttonVariants({ variant: i === 0 ? 'secondary' : 'ghost', size: 'sm' })}
          >
            {f.label}
          </button>
        ))}
      </div>
    </div>

    <div class="mt-3 divide-y divide-border rounded-lg border border-border" data-list-rows>
      {page.data.map((entry) => (
        <FitnessCard entry={entry} />
      ))}
    </div>
    <p class="mt-3 hidden text-sm text-muted-foreground" data-empty-msg>No activities in this category on this page.</p>
  </section>

  <nav class="mt-8 flex items-center justify-between text-sm">
    <a
      href={page.url.prev ?? '#'}
      aria-disabled={!page.url.prev}
      class={buttonVariants({ variant: 'outline' }) + (page.url.prev ? '' : ' pointer-events-none opacity-50')}
    >
      ← Newer
    </a>
    <span class="text-muted-foreground">Page {page.currentPage} of {page.lastPage}</span>
    <a
      href={page.url.next ?? '#'}
      aria-disabled={!page.url.next}
      class={buttonVariants({ variant: 'outline' }) + (page.url.next ? '' : ' pointer-events-none opacity-50')}
    >
      Older →
    </a>
  </nav>
</Layout>

<script>
  function initFilters(root: ParentNode) {
    const section = root.querySelector<HTMLElement>('[data-fitness-list]');
    if (!section) return;

    const buttons = section.querySelectorAll<HTMLButtonElement>('[data-filter]');
    const rows = section.querySelectorAll<HTMLElement>('[data-list-rows] [data-category]');
    const emptyMsg = section.querySelector<HTMLElement>('[data-empty-msg]');
    if (buttons.length === 0) return;

    const secondary =
      'bg-secondary text-secondary-foreground hover:bg-[color-mix(in_oklch,var(--secondary),var(--foreground)_5%)]';
    const ghost = 'hover:bg-muted hover:text-foreground dark:hover:bg-muted/50';
    const secondaryCls = secondary.split(' ');
    const ghostCls = ghost.split(' ');

    const apply = (key: string) => {
      let visible = 0;
      rows.forEach((row) => {
        const match = key === 'all' || row.dataset.category === key;
        row.classList.toggle('hidden', !match);
        if (match) visible += 1;
      });
      emptyMsg?.classList.toggle('hidden', visible !== 0);

      buttons.forEach((btn) => {
        const active = btn.dataset.filter === key;
        btn.setAttribute('aria-pressed', active ? 'true' : 'false');
        btn.classList.remove(...secondaryCls, ...ghostCls);
        btn.classList.add(...(active ? secondaryCls : ghostCls));
      });
    };

    buttons.forEach((btn) => btn.addEventListener('click', () => apply(btn.dataset.filter ?? 'all')));
  }

  initFilters(document);
  document.addEventListener('astro:page-load', () => initFilters(document));
</script>
